{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yourorg/meai-utility-impl/schemas/provider-config.json",
  "title": "MultiProvider Configuration Schema",
  "description": "MEAI マルチプロバイダー抽象化ライブラリの構成スキーマ",
  "type": "object",
  "properties": {
    "MultiProvider": {
      "type": "object",
      "description": "マルチプロバイダー設定のルートオブジェクト",
      "properties": {
        "Provider": {
          "type": "string",
          "description": "使用するLLMプロバイダー名",
          "enum": ["OpenAI", "AzureOpenAI", "OpenAICompatible", "GitHubCopilot"]
        },
        "OpenAI": {
          "type": "object",
          "description": "OpenAI API 固有設定",
          "properties": {
            "ApiKey": {
              "type": "string",
              "description": "OpenAI APIキー（環境変数 ${OPENAI_API_KEY} 形式推奨）",
              "minLength": 1
            },
            "OrganizationId": {
              "type": ["string", "null"],
              "description": "OpenAI 組織ID（オプション）"
            },
            "BaseUrl": {
              "type": ["string", "null"],
              "description": "カスタムベースURL（デフォルト: https://api.openai.com/v1）",
              "format": "uri"
            },
            "ModelName": {
              "type": "string",
              "description": "使用するモデル名",
              "default": "gpt-4"
            },
            "TimeoutSeconds": {
              "type": "integer",
              "description": "HTTPリクエストタイムアウト（秒）",
              "minimum": 1,
              "default": 60
            }
          },
          "required": ["ApiKey"],
          "additionalProperties": false
        },
        "AzureOpenAI": {
          "type": "object",
          "description": "Azure OpenAI Service 固有設定",
          "properties": {
            "Endpoint": {
              "type": "string",
              "description": "Azure OpenAI エンドポイントURL",
              "format": "uri",
              "pattern": "^https://.*\\.openai\\.azure\\.com$"
            },
            "DeploymentName": {
              "type": "string",
              "description": "デプロイメント名",
              "minLength": 1
            },
            "ApiVersion": {
              "type": "string",
              "description": "Azure OpenAI APIバージョン",
              "default": "2024-02-15-preview"
            },
            "Authentication": {
              "type": "object",
              "description": "認証方式の設定",
              "properties": {
                "Type": {
                  "type": "string",
                  "description": "認証方式",
                  "enum": ["ApiKey", "EntraId"]
                },
                "ApiKey": {
                  "type": ["string", "null"],
                  "description": "APIキー（Type=ApiKey の場合は必須）",
                  "minLength": 1
                }
              },
              "required": ["Type"],
              "additionalProperties": false,
              "if": {
                "properties": { "Type": { "const": "ApiKey" } }
              },
              "then": {
                "required": ["ApiKey"]
              }
            },
            "TimeoutSeconds": {
              "type": "integer",
              "description": "HTTPリクエストタイムアウト（秒）",
              "minimum": 1,
              "default": 60
            }
          },
          "required": ["Endpoint", "DeploymentName", "Authentication"],
          "additionalProperties": false
        },
        "OpenAICompatible": {
          "type": "object",
          "description": "OpenAI互換エンドポイント固有設定",
          "properties": {
            "BaseUrl": {
              "type": "string",
              "description": "OpenAI互換エンドポイントのベースURL",
              "format": "uri"
            },
            "ApiKey": {
              "type": ["string", "null"],
              "description": "APIキー（ローカル実行時は不要な場合が多い）"
            },
            "ModelName": {
              "type": "string",
              "description": "使用するモデル名（互換実装固有の識別子）",
              "minLength": 1
            },
            "ModelMapping": {
              "type": ["object", "null"],
              "description": "OpenAIモデル名をローカルモデル名にマッピング",
              "additionalProperties": {
                "type": "string"
              }
            },
            "StrictCompatibilityMode": {
              "type": "boolean",
              "description": "true時は互換性エラーで失敗、false時はベストエフォート",
              "default": false
            },
            "TimeoutSeconds": {
              "type": "integer",
              "description": "HTTPリクエストタイムアウト（秒）",
              "minimum": 1,
              "default": 60
            }
          },
          "required": ["BaseUrl", "ModelName"],
          "additionalProperties": false
        },
        "GitHubCopilot": {
          "type": "object",
          "description": "GitHub Copilot SDK 固有設定",
          "properties": {
            "CliPath": {
              "type": ["string", "null"],
              "description": "Copilot CLIの実行ファイルパス（nullの場合はPATH検索）"
            },
            "AuthToken": {
              "type": "string",
              "description": "GitHub認証トークン（環境変数 ${GITHUB_TOKEN} 形式推奨）",
              "minLength": 1
            },
            "TimeoutSeconds": {
              "type": "integer",
              "description": "Copilot呼び出しタイムアウト（秒）",
              "minimum": 1,
              "default": 120
            },
            "EnableProcessPooling": {
              "type": "boolean",
              "description": "CLIプロセスを複数リクエスト間で再利用するか",
              "default": true
            },
            "MaxProcessIdleSeconds": {
              "type": "integer",
              "description": "アイドルプロセスを終了するまでの秒数",
              "minimum": 1,
              "default": 300
            }
          },
          "required": ["AuthToken"],
          "additionalProperties": false
        },
        "Common": {
          "type": "object",
          "description": "全プロバイダー共通の設定",
          "properties": {
            "DefaultTemperature": {
              "type": ["number", "null"],
              "description": "デフォルトの温度パラメータ（0.0-2.0）",
              "minimum": 0.0,
              "maximum": 2.0,
              "default": 0.7
            },
            "DefaultMaxTokens": {
              "type": ["integer", "null"],
              "description": "デフォルトの最大トークン数",
              "minimum": 1,
              "default": 1000
            },
            "EnableTelemetry": {
              "type": "boolean",
              "description": "OpenTelemetry トレーシングを有効化",
              "default": true
            },
            "CapturePrompts": {
              "type": "boolean",
              "description": "プロンプト/レスポンス内容をテレメトリに記録するか",
              "default": false
            },
            "LogRequestResponse": {
              "type": "boolean",
              "description": "リクエスト/レスポンスの詳細をログに出力するか",
              "default": false
            },
            "MaskSensitiveData": {
              "type": "boolean",
              "description": "APIキー等をログでマスキングするか",
              "default": true
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["Provider"],
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": { "Provider": { "const": "OpenAI" } },
          "required": ["OpenAI"]
        },
        {
          "properties": { "Provider": { "const": "AzureOpenAI" } },
          "required": ["AzureOpenAI"]
        },
        {
          "properties": { "Provider": { "const": "OpenAICompatible" } },
          "required": ["OpenAICompatible"]
        },
        {
          "properties": { "Provider": { "const": "GitHubCopilot" } },
          "required": ["GitHubCopilot"]
        }
      ]
    }
  },
  "required": ["MultiProvider"]
}
